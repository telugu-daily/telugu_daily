import React, { useState, useEffect } from 'react';
import { View, Text, StyleSheet, ScrollView, TouchableOpacity } from 'react-native';
import { LinearGradient } from 'expo-linear-gradient';
import { TrendingUp, Award, Target, Calendar } from 'lucide-react-native';
import {
  getUserJoinDate,
  getUserCurrentDay,
  loadTotalSentencesLearned,
  loadTotalMasteredSentences,
  loadActualDaysLearned as loadActualDaysLearnedUtil,
  calculateCurrentStreak as calculateCurrentStreakUtil,
  calculateLongestStreak as calculateLongestStreakUtil
} from '@/utils/userJourney';

export default function ProgressScreen() {
  // Real dynamic state
  const [currentDay, setCurrentDay] = useState(0);
  const [totalSentences, setTotalSentences] = useState(0);
  const [completedSentences, setCompletedSentences] = useState(0);
  const [masteredSentences, setMasteredSentences] = useState(0);
  const [currentStreak, setCurrentStreak] = useState(0);
  const [longestStreak, setLongestStreak] = useState(0);
  const [actualDaysLearned, setActualDaysLearned] = useState(0);

  // Load all data using shared utilities
  const loadAllData = async () => {
    try {
      const calculatedCurrentDay = await getUserCurrentDay();
      setCurrentDay(calculatedCurrentDay);

      const [totalCount, totalMastered, streakCount, longestStreakCount, daysLearned] = await Promise.all([
        loadTotalSentencesLearned(calculatedCurrentDay),
        loadTotalMasteredSentences(calculatedCurrentDay),
        calculateCurrentStreakUtil(),
        calculateLongestStreakUtil(),
        loadActualDaysLearnedUtil(),
      ]);

      setTotalSentences(totalCount);
      setCompletedSentences(totalCount);
      setMasteredSentences(totalMastered);
      setCurrentStreak(streakCount);
      setLongestStreak(longestStreakCount);
      setActualDaysLearned(daysLearned);
    } catch (error) {
      console.log('Error loading all data:', error);
    }
  };

  useEffect(() => {
    loadAllData();
  }, []);

  // Dynamic progress data
  const progressData = {
    dailyStreak: currentStreak,
    totalDays: actualDaysLearned,
    completionRate: totalSentences > 0 ? Math.round((completedSentences / totalSentences) * 100) : 0,
    masteryRate: completedSentences > 0 ? Math.round((masteredSentences / completedSentences) * 100) : 0,
    weeklyGoal: 350,
    currentProgress: totalSentences,
  };

  return (
    <View style={styles.container}>
      {/* Header */}
      <LinearGradient colors={['#4ECDC4', '#44B3AC']} style={styles.header}>
        <View style={styles.headerContent}>
          <Text style={styles.headerTitle}>Your Progress</Text>
        </View>
        <Text style={styles.headerSubtitle}>Keep up the great work!</Text>

        {/* Dynamic Streak Display */}
        <View style={styles.streakContainer}>
          <Text style={styles.streakNumber}>{currentStreak}</Text>
          <Text style={styles.streakLabel}>Day Streak 🔥</Text>
        </View>
      </LinearGradient>

      <ScrollView style={styles.content} showsVerticalScrollIndicator={false}>
        {/* Dynamic Progress Stats */}
        <View style={styles.statsContainer}>
          <View style={styles.statCard}>
            <TrendingUp size={24} color={'#4ECDC4'} />
            <Text style={styles.statNumber}>{progressData.completionRate}%</Text>
            <Text style={styles.statLabel}>Completion Rate</Text>
          </View>

          <View style={styles.statCard}>
            <Award size={24} color={'#F5A623'} />
            <Text style={styles.statNumber}>{masteredSentences}</Text>
            <Text style={styles.statLabel}>Mastered</Text>
          </View>

          <View style={styles.statCard}>
            <Target size={24} color={'#27AE60'} />
            <Text style={styles.statNumber}>{actualDaysLearned}</Text>
            <Text style={styles.statLabel}>Days Learned</Text>
          </View>
        </View>

        {/* Dynamic Weekly Progress */}
        <View style={styles.sectionContainer}>
          <Text style={styles.sectionTitle}>This Week</Text>

          <View style={styles.weeklyGoal}>
            <Text style={styles.goalText}>Weekly Goal: {progressData.currentProgress}/{progressData.weeklyGoal}</Text>
            <View style={styles.goalBar}>
              <View style={[
                styles.goalProgress,
                { width: `${Math.min(100, (progressData.currentProgress / progressData.weeklyGoal) * 100)}%` }
              ]} />
            </View>
          </View>
        </View>

        {/* Dynamic Memory Levels */}
        <View style={styles.sectionContainer}>
          <Text style={styles.sectionTitle}>Memory Matrix</Text>
          
          <View style={styles.memoryLevels}>
            <View style={styles.memoryLevel}>
              <Text style={styles.memoryIcon}>🆕</Text>
              <View style={styles.memoryInfo}>
                <Text style={styles.memoryTitle}>New</Text>
                <Text style={styles.memoryDesc}>Daily review</Text>
                <Text style={styles.memoryCount}>{Math.max(0, totalSentences - masteredSentences)} sentences</Text>
              </View>
            </View>

            <View style={styles.memoryLevel}>
              <Text style={styles.memoryIcon}>🔄</Text>
              <View style={styles.memoryInfo}>
                <Text style={styles.memoryTitle}>Review</Text>
                <Text style={styles.memoryDesc}>Every 3 days</Text>
                <Text style={styles.memoryCount}>{Math.floor(masteredSentences * 0.3)} sentences</Text>
              </View>
            </View>

            <View style={styles.memoryLevel}>
              <Text style={styles.memoryIcon}>🎯</Text>
              <View style={styles.memoryInfo}>
                <Text style={styles.memoryTitle}>Master</Text>
                <Text style={styles.memoryDesc}>Weekly review</Text>
                <Text style={styles.memoryCount}>{masteredSentences} sentences</Text>
              </View>
            </View>
          </View>
        </View>
        
        {/* Dynamic Progress Ring Detail */}
        <View style={styles.sectionContainer}>
          <Text style={styles.sectionTitle}>Detailed Progress</Text>
          
          <View style={styles.progressDetails}>
            <View style={styles.progressRingLarge}>
              <Text style={styles.progressRingNumber}>{completedSentences}</Text>
              <Text style={styles.progressRingTotal}>/ {totalSentences || 'Loading'}</Text>
              <Text style={styles.progressRingLabel}>Completed</Text>
            </View>
            <View style={styles.progressBreakdown}>
              <View style={styles.breakdownItem}>
                <View style={[styles.breakdownDot, { backgroundColor: '#27AE60' }]} />
                <Text style={styles.breakdownLabel}>Mastered: {masteredSentences}</Text>
              </View>
              <View style={styles.breakdownItem}>
                <View style={[styles.breakdownDot, { backgroundColor: '#F5A623' }]} />
                <Text style={styles.breakdownLabel}>Learning: {Math.max(0, completedSentences - masteredSentences)}</Text>
              </View>
              <View style={styles.breakdownItem}>
                <View style={[styles.breakdownDot, { backgroundColor: '#E1E1E6' }]} />
                <Text style={styles.breakdownLabel}>Remaining: {Math.max(0, (actualDaysLearned * 50) - completedSentences)}</Text>
              </View>
            </View>
          </View>
        </View>

        {/* Real Performance Metrics */}
        <View style={styles.sectionContainer}>
          <Text style={styles.sectionTitle}>Learning Analytics</Text>
          
          <View style={styles.analyticsGrid}>
            <View style={styles.analyticsCard}>
              <Text style={styles.analyticsNumber}>{currentStreak}</Text>
              <Text style={styles.analyticsLabel}>Current Streak</Text>
            </View>
            
            <View style={styles.analyticsCard}>
              <Text style={styles.analyticsNumber}>{longestStreak}</Text>
              <Text style={styles.analyticsLabel}>Best Streak</Text>
            </View>
            
            <View style={styles.analyticsCard}>
              <Text style={styles.analyticsNumber}>{progressData.masteryRate}%</Text>
              <Text style={styles.analyticsLabel}>Mastery Rate</Text>
            </View>
            
            <View style={styles.analyticsCard}>
              <Text style={styles.analyticsNumber}>{Math.round(totalSentences / Math.max(1, actualDaysLearned))}</Text>
              <Text style={styles.analyticsLabel}>Daily Average</Text>
            </View>
          </View>
        </View>
      </ScrollView>
    </View>
  );
}

const styles = StyleSheet.create({
  container: {
    flex: 1,
    backgroundColor: '#F5F5F5',
  },
  header: {
    paddingTop: 46,
    paddingBottom: 3,
    paddingHorizontal: 20,
  },
  headerContent: {
    flexDirection: 'row',
    justifyContent: 'space-between',
