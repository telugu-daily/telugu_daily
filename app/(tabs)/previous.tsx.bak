    color: '#FFFFFF',
    fontFamily: 'Poppins-Medium',
    fontSize: 10,
  },
  teluguContainer: {
    flexDirection: 'row',
    alignItems: 'flex-start',
    marginBottom: 8,
  },
  teluguText: {
    flex: 1,
    fontSize: 18,
    fontFamily: 'NotoSansTelugu-Regular',
    color: '#2C3E50',
    lineHeight: 30,
  },
  playIcon: {
    marginLeft: 8,
    marginTop: 4,
  },
  englishContainer: {
    flexDirection: 'row',
    alignItems: 'flex-start',
  },
  englishText: {
    flex: 1,
    fontSize: 14,
    fontFamily: 'Poppins-Regular',
    color: '#2C3E50',
    lineHeight: 20,
  },
  summaryContainer: {
    backgroundColor: '#FFFFFF',
    borderRadius: 12,
