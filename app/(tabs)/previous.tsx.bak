import React, { useState, useEffect } from 'react';
import { View, Text, StyleSheet, ScrollView, TouchableOpacity } from 'react-native';
import { LinearGradient } from 'expo-linear-gradient';
import { Play, ChevronDown, ChevronRight, Lock } from 'lucide-react-native';
import * as Speech from 'expo-speech';
import { fetchSentencesByDay, Sentence } from '@/utils/api';
import AsyncStorage from '@react-native-async-storage/async-storage';
import {
  getUserCurrentDay,
  loadTotalSentencesLearned,
  loadTotalMasteredSentences,
  loadActualDaysLearned
} from '@/utils/userJourney';

export default function PreviousScreen() {
  // Calendar-based state
  const [currentDay, setCurrentDay] = useState(1);
  const [actualDaysLearned, setActualDaysLearned] = useState(0);
  const [totalSentencesLearned, setTotalSentencesLearned] = useState(0);
  const [masteredSentencesCount, setMasteredSentencesCount] = useState(0);
  const [expandedDays, setExpandedDays] = useState<{ [key: number]: boolean }>({});
  const [unlockedDays, setUnlockedDays] = useState<{ [key: number]: boolean }>({});
  const [daySentencesCache, setDaySentencesCache] = useState<{ [key: number]: Sentence[] }>({});

  const totalDays = 200;

  // Load real data from AsyncStorage
  useEffect(() => {
    loadAllData();
  }, []);

  // Load current day using centralized utility
  const loadCurrentDay = async () => {
    try {
      const calculatedCurrentDay = await getUserCurrentDay();
      setCurrentDay(calculatedCurrentDay);
      
      // Auto-unlock current day and all previous days
      const autoUnlockedDays: { [key: number]: boolean } = {};
      for (let i = 1; i <= calculatedCurrentDay; i++) {
        autoUnlockedDays[i] = true;
      }
      
      setUnlockedDays(prev => ({ ...prev, ...autoUnlockedDays }));
      return calculatedCurrentDay;
    } catch (error) {
      console.log('Error loading current day:', error);
      return 1;
    }
  };

  // Load all data using centralized utilities
  const loadAllData = async () => {
    try {
      const calculatedCurrentDay = await loadCurrentDay();
      
      const [daysLearned, totalSentences, masteredSentences] = await Promise.all([
        loadActualDaysLearned(),
        loadTotalSentencesLearned(calculatedCurrentDay),
        loadTotalMasteredSentences(calculatedCurrentDay)
      ]);
      
      setActualDaysLearned(daysLearned);
      setTotalSentencesLearned(totalSentences);
      setMasteredSentencesCount(masteredSentences);
    } catch (error) {
      console.log('Error loading all data:', error);
    }
  };

  const handleTextToSpeech = async (text: string, isEnglish: boolean = true) => {
    try {
      const language = isEnglish ? 'en-US' : 'te-IN';
      await Speech.speak(text, {
        language,
        pitch: 1.0,
        rate: 0.8,
      });
    } catch (error) {
      console.log('TTS Error:', error);
    }
  };

  const toggleDayExpansion = async (day: number) => {
    const isDayUnlocked = day <= currentDay || unlockedDays[day];
    if (!isDayUnlocked) {
      return;
    }

    // If expanding and not cached, fetch sentences
    if (!expandedDays[day] && !daySentencesCache[day]) {
      try {
        const data = await fetchSentencesByDay(day);
        if (data && data.length > 0) {
          setDaySentencesCache(prev => ({ ...prev, [day]: data }));
        }
      } catch (error) {
        console.log('Failed to fetch sentences for day', day, error);
      }
    }

    setExpandedDays(prev => ({
      ...prev,
      [day]: !prev[day]
    }));
  };

  const getDaysSentences = (day: number) => {
    return daySentencesCache[day] || [];
  };

  // ✅ UPDATED: Check if day is unlocked (current day + previous days automatically unlocked)
  const isDayUnlocked = (day: number) => {
    return day <= currentDay || unlockedDays[day];
  };

  const getUnlockedDaysCount = () => {
    return Object.keys(unlockedDays).length;
  };


  return (
    <View style={styles.container}>
      {/* Header with Real Stats */}
      <LinearGradient colors={['#4ECDC4', '#44B3AC']} style={styles.header}>
        <View style={styles.headerContent}>
          <Text style={styles.headerTitle}>Previous Days</Text>
        </View>
        
        {/* ✅ Real-time stats */}
        <Text style={styles.headerSubtitle}>
          {totalSentencesLearned} sentences learned • {actualDaysLearned} days mastered • {masteredSentencesCount} mastered • {getUnlockedDaysCount()} days unlocked • {totalDays - currentDay} days remaining
        </Text>
      </LinearGradient>

      <ScrollView style={styles.content} showsVerticalScrollIndicator={false}>
        {Array.from({ length: totalDays }, (_, index) => {
          const day = index + 1;
          const daySentences = getDaysSentences(day);
          const isExpanded = expandedDays[day];
          const isUnlocked = isDayUnlocked(day);

          return (
            <View
              key={day}
              style={[
                styles.dayContainer,
                !isUnlocked && styles.lockedDayContainer
              ]}
            >
              <TouchableOpacity
                style={styles.dayHeader}
                onPress={() => toggleDayExpansion(day)}
              >
                <View style={styles.dayHeaderLeft}>
                  <Text style={[
                    styles.dayNumber,
                    !isUnlocked && styles.lockedDayNumber
                  ]}>
                    Day {day}
                  </Text>
                  <Text style={[
                    styles.dayRange,
                    !isUnlocked && styles.lockedDayRange
                  ]}>
                    Sentences {(day - 1) * 50 + 1} - {day * 50}
                  </Text>
                </View>

                <View style={styles.dayHeaderRight}>
                  <View style={[
                    styles.dayBadge,
                    !isUnlocked && styles.lockedDayBadge
                  ]}>
                    <Text style={styles.dayBadgeText}>50</Text>
                  </View>

                  {!isUnlocked ? (
                    <Lock size={20} color="#C7C7CC" />
                  ) : isExpanded ? (
                    <ChevronDown size={20} color="#2C3E50" />
                  ) : (
                    <ChevronRight size={20} color="#2C3E50" />
                  )}
                </View>
              </TouchableOpacity>

              {isExpanded && isUnlocked && (
                <View style={styles.sentencesContainer}>
                  {daySentences.map((sentence, sentenceIndex) => {
                    const globalIndex = (day - 1) * 50 + sentenceIndex;
                    
                    return (
                      <View key={globalIndex} style={styles.sentenceCard}>
                        <View style={styles.cardHeader}>
                          <Text style={styles.sentenceNumber}>#{globalIndex + 1}</Text>
                          <View style={styles.dayTag}>
                            <Text style={styles.dayTagText}>
                              Day {day}
                            </Text>
                          </View>
                        </View>

                        <TouchableOpacity
                          style={styles.teluguContainer}
                          onPress={() => handleTextToSpeech(sentence.telugu, false)}
                        >
                          <Text style={styles.teluguText}>{sentence.telugu}</Text>
                          <Play size={16} color="#4ECDC4" style={styles.playIcon} />
                        </TouchableOpacity>

                        <TouchableOpacity
                          style={styles.englishContainer}
                          onPress={() => handleTextToSpeech(sentence.english, true)}
                        >
                          <Text style={styles.englishText}>{sentence.english}</Text>
                          <Play size={16} color="#F5A623" style={styles.playIcon} />
                        </TouchableOpacity>
                      </View>
                    );
                  })}
                </View>
              )}
            </View>
          );
        })}

        {/* ✅ Real-time Summary Stats */}
        <View style={styles.summaryContainer}>
          <Text style={styles.summaryTitle}>Learning Summary</Text>
          
          <View style={styles.summaryStats}>
            <View style={styles.statCard}>
              <Text style={styles.statNumber}>{currentDay}</Text>
              <Text style={styles.statLabel}>Current Day</Text>
            </View>
            
            <View style={styles.statCard}>
              <Text style={styles.statNumber}>{actualDaysLearned}</Text>
              <Text style={styles.statLabel}>Days Mastered</Text>
            </View>
            
            <View style={styles.statCard}>
              <Text style={styles.statNumber}>{getUnlockedDaysCount()}</Text>
              <Text style={styles.statLabel}>Days Unlocked</Text>
            </View>
          </View>

        </View>
      </ScrollView>
    </View>
  );
}

const styles = StyleSheet.create({
  container: {
    flex: 1,
    backgroundColor: '#F5F5F5',
  },
  header: {
    paddingTop: 70,
    paddingBottom: 20,
    paddingHorizontal: 20,
  },
  headerContent: {
    flexDirection: 'row',
    justifyContent: 'space-between',
    alignItems: 'center',
    marginBottom: 8,
  },
  headerTitle: {
    fontSize: 24,
    fontFamily: 'Poppins-SemiBold',
    color: '#FFFFFF',
  },
  headerSubtitle: {
    fontSize: 14,
    fontFamily: 'Poppins-Regular',
    color: '#FFFFFF',
    opacity: 0.9,
  },
  content: {
    flex: 1,
    paddingHorizontal: 20,
  },
  dayContainer: {
    backgroundColor: '#FFFFFF',
    borderRadius: 12,
    marginVertical: 8,
    shadowColor: '#000',
    shadowOffset: { width: 0, height: 2 },
    shadowOpacity: 0.1,
    shadowRadius: 4,
    elevation: 3,
  },
  lockedDayContainer: {
    backgroundColor: '#F8F9FA',
    opacity: 0.8,
    borderWidth: 2,
    borderColor: '#E1E1E6',
    borderStyle: 'dashed',
  },
  dayHeader: {
