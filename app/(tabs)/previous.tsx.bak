    borderRadius: 8,
    padding: 12,
    marginVertical: 4,
  },
  cardHeader: {
    flexDirection: 'row',
    justifyContent: 'space-between',
    alignItems: 'center',
    marginBottom: 8,
  },
  sentenceNumber: {
    fontSize: 12,
    fontFamily: 'Poppins-Medium',
    color: '#4ECDC4',
  },
  dayTag: {
    backgroundColor: '#F5A623',
    borderRadius: 6,
    paddingHorizontal: 6,
    paddingVertical: 2,
  },
